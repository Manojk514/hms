# Allow access to uploaded files
<IfModule mod_rewrite.c>
    RewriteEngine Off
</IfModule>

# Allow only image files
<FilesMatch "\.(jpg|jpeg|png|webp|gif)$">
    Order Allow,Deny
    Allow from all
</FilesMatch>

# Deny access to PHP files
<FilesMatch "\.php$">
    Order Deny,Allow
    Deny from all
</FilesMatch>

# Prevent directory listing
Options -Indexes
